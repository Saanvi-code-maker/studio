/**
 * ShikshaSetu Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a dual-role authorization model (Students and Teachers). 
 * Security is enforced primarily through document ownership and denormalized relationship 
 * links (assignedTeacherId) to ensure high performance and Authorization Independence.
 *
 * Data Structure:
 * - /studentProfiles & /teacherProfiles: Top-level root documents identified by Auth UID.
 * - /learningModules (and sub-collections): Public curriculum content.
 * - /studentResponses, /explanations, /learningProgresses: Private student data, shared with assigned teachers via denormalization.
 * - /misconceptions: Aggregated teacher-only insights.
 *
 * Key Security Decisions:
 * 1. Denormalization for Authorization: Student-specific records (Responses, Progress) contain both
 *    the 'studentId' and 'assignedTeacherId' to allow O(1) authorization checks without additional get() calls.
 * 2. Identity Verification: All write operations and private read operations strictly use request.auth.uid.
 * 3. Structural Segregation: Curriculum content is globally readable, while student performance data 
 *    is restricted to the owner and their specific mentor.
 * 4. Relational Integrity: On creation of user-scoped data, the rules force the internal ID and ownership
 *    fields to match the authenticated user's state.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the provided UID matches the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user exists in the teacherProfiles collection.
     */
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/teacherProfiles/$(request.auth.uid));
    }

    /**
     * @description Checks if the document exists and is owned by the user.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /**
     * @description Checks if the user is the student owner of the resource data.
     */
    function isDataStudent(data) {
      return isSignedIn() && request.auth.uid == data.studentId;
    }

    /**
     * @description Checks if the user is the assigned teacher for the resource data.
     */
    function isAssignedTeacher(data) {
      return isSignedIn() && request.auth.uid == data.assignedTeacherId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for student profile management.
     * @path /studentProfiles/{studentId}
     * @allow (create) if studentId matches auth.uid.
     * @deny (update) if studentId is modified or doesn't match auth.uid.
     * @principle Self-Creation and Ownership.
     */
    match /studentProfiles/{studentId} {
      allow get, list: if isOwner(studentId);
      allow create: if isOwner(studentId) && request.resource.data.id == studentId;
      allow update: if isExistingOwner(studentId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(studentId);
    }

    /**
     * @description Rules for teacher profile management.
     * @path /teacherProfiles/{teacherId}
     * @allow (get) if authenticated teacher is accessing their own profile.
     * @deny (create) if teacherId doesn't match auth.uid.
     * @principle Self-Creation and Identity Verification.
     */
    match /teacherProfiles/{teacherId} {
      allow get, list: if isOwner(teacherId);
      allow create: if isOwner(teacherId) && request.resource.data.id == teacherId;
      allow update: if isExistingOwner(teacherId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(teacherId);
    }

    /**
     * @description Rules for curriculum content (Modules, Lessons, Questions).
     * @path /learningModules/{learningModuleId}
     * @allow (get, list) for any user.
     * @deny (write) if user is not a verified teacher.
     * @principle Public Read with Role-Based Writes.
     */
    match /learningModules/{learningModuleId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement strict owner-only writes. The 'LearningModule' entity is missing an 'ownerId' field.
      allow create, update, delete: if isTeacher(); // TODO: Add specific author/owner validation once schema is updated.

      match /lessons/{lessonId} {
        allow get, list: if true;
        allow create, update, delete: if isTeacher();
        
        match /questions/{questionId} {
          allow get, list: if true;
          allow create, update, delete: if isTeacher();
        }
      }
    }

    /**
     * @description Rules for student response records.
     * @path /studentResponses/{studentResponseId}
     * @allow (create) for the student who owns the response.
     * @allow (get) for student owner or their assigned teacher.
     * @deny (list) for anyone other than the owner or assigned teacher.
     * @principle Shared Access via Denormalized Collaborators.
     */
    match /studentResponses/{studentResponseId} {
      allow get: if isDataStudent(resource.data) || isAssignedTeacher(resource.data);
      allow list: if isSignedIn() && (request.query.limit <= 100); // Listing requires query filtering on studentId or assignedTeacherId
      allow create: if isDataStudent(request.resource.data);
      allow update: if isExistingOwner(resource.data.studentId) && request.resource.data.studentId == resource.data.studentId;
      allow delete: if isExistingOwner(resource.data.studentId);
    }

    /**
     * @description Rules for AI-generated explanations.
     * @path /explanations/{explanationId}
     * @allow (get) for the student or their assigned teacher.
     * @deny (write) by clients; managed by Cloud Functions.
     * @principle Shared Access via Denormalized Collaborators.
     */
    match /explanations/{explanationId} {
      allow get: if isDataStudent(resource.data) || isAssignedTeacher(resource.data);
      allow list: if isSignedIn();
      allow create, update, delete: if false; // Managed via server-side logic
    }

    /**
     * @description Rules for student learning progress.
     * @path /learningProgresses/{learningProgressId}
     * @allow (update) for the student to track their own progress.
     * @allow (get) for the student or their assigned teacher.
     * @principle Shared Access via Denormalized Collaborators.
     */
    match /learningProgresses/{learningProgressId} {
      allow get: if isDataStudent(resource.data) || isAssignedTeacher(resource.data);
      allow list: if isSignedIn();
      allow create: if isDataStudent(request.resource.data);
      allow update: if isExistingOwner(resource.data.studentId) && request.resource.data.studentId == resource.data.studentId;
      allow delete: if isExistingOwner(resource.data.studentId);
    }

    /**
     * @description Rules for common student misconceptions.
     * @path /misconceptions/{misconceptionId}
     * @allow (get, list) for verified teachers only.
     * @deny (write) by all clients.
     * @principle Role-Based Access for Teacher Insights.
     */
    match /misconceptions/{misconceptionId} {
      allow get, list: if isTeacher();
      allow create, update, delete: if false; // Read-only aggregated data for clients
    }

  }
}