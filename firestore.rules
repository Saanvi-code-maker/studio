/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset implements a robust, role-based access control (RBAC) and ownership model.
 * It distinguishes between 'Students' and 'Teachers' to manage permissions.
 *
 * ## Key Security Decisions
 * - **DBAC (Database Access Control):** Teacher privileges are verified by checking for the 
 *   existence of a document in the `/teachers` collection.
 * - **Demo Mode:** Added a rule allowing users to create their own teacher record for hackathon testing.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid));
    }

    function isDocOwner() {
      return isSignedIn() && resource.data.studentId == request.auth.uid;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isTeacher() || isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /teachers/{teacherId} {
      allow get: if isSignedIn();
      allow list: if isTeacher();
      // ALLOWED FOR HACKATHON DEMO: Users can promote themselves during signup
      allow create: if isOwner(teacherId);
      allow update, delete: if false;
    }

    match /learningModules/{moduleId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isTeacher();

      match /contents/{contentId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isTeacher();

        match /questions/{questionId} {
          allow get, list: if isSignedIn();
          allow create, update, delete: if isTeacher();
        }
      }
    }

    match /studentResponses/{responseId} {
      allow get: if isTeacher() || isDocOwner();
      allow list: if isTeacher() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update: if resource != null && (isTeacher() || (isDocOwner() && request.resource.data.studentId == resource.data.studentId));
      allow delete: if resource != null && (isTeacher() || isDocOwner());
    }

    match /aiAnalyses/{analysisId} {
      allow get: if isTeacher() || isDocOwner();
      allow list: if isTeacher() || (isSignedIn() && request.query.limit <= 100);
      allow create, update, delete: if isTeacher();
    }
  }
}