
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the application, either a student or a teacher.",
      "properties": {
        "id": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher"] },
        "languagePreference": { "type": "string", "enum": ["en", "hi", "kn"] },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "displayName", "email", "role", "createdAt"]
    },
    "StudentResponse": {
      "title": "StudentResponse",
      "type": "object",
      "description": "Records a student's answer to a specific question.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "lessonId": { "type": "string" },
        "questionId": { "type": "string" },
        "responseValue": { "type": "string" },
        "isCorrect": { "type": "boolean" },
        "submittedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "lessonId", "questionId", "responseValue", "isCorrect", "submittedAt"]
    },
    "AIAnalysis": {
      "title": "AIAnalysis",
      "type": "object",
      "description": "AI-generated feedback for a student response.",
      "properties": {
        "id": { "type": "string" },
        "studentResponseId": { "type": "string" },
        "studentId": { "type": "string" },
        "analysisResultType": { "type": "string", "enum": ["correct", "confused", "partial_understanding", "guessing"] },
        "explanationText": { "type": "string" },
        "storyText": { "type": "string" },
        "visualDescription": { "type": "string" },
        "mindmap": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string", "format": "uri" },
        "generatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentResponseId", "studentId", "analysisResultType", "explanationText", "generatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Individual user profiles."
    },
    "/teachers/{teacherId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Teacher verification records."
    },
    "/studentResponses/{responseId}": {
      "schema": { "$ref": "#/backend/entities/StudentResponse" },
      "description": "Student answer logs."
    },
    "/aiAnalyses/{analysisId}": {
      "schema": { "$ref": "#/backend/entities/AIAnalysis" },
      "description": "AI-generated cognitive feedback."
    }
  }
}
